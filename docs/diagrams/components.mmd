---
title: RepoQuery Component Architecture
---
%%{init: {'theme':'base', 'themeVariables': {'primaryColor':'#e1f5fe','secondaryColor':'#fff3e0','tertiaryColor':'#f3e5f5'}}}%%
graph TB
    subgraph CLI["CLI Layer (main.rs)"]
        Main[main.rs<br/>CLI Entry Point<br/>Clap commands]
    end
    
    subgraph NewSync["Sync Layer"]
        SyncOrch[SyncOrchestrator<br/>Coordination logic]
        GitHubAdapt[GitHubAdapter<br/>octocrab client]
        CBAdapt[CodebergAdapter<br/>stub for future]
        GLAdapt[GitLabAdapter<br/>stub for future]
        SyncCache[SyncCache<br/>ETag + TTL]
        Progress[ProgressTracker<br/>indicatif bars]
        SyncLock[SyncLock<br/>fs2 exclusive file lock]
        FgatPool[FgatPool<br/>Token distribution<br/>Round-robin]
        Acquired[AcquiredToken<br/>RAII guard]
    end
    
    subgraph NewConfig["Config Layer"]
        ConfigMgr[ConfigManager<br/>TOML parsing]
        CredMgr[CredentialManager<br/>env/file/keychain<br/>symlink+TOCTOU]
    end
    
    subgraph Core["Core Processing"]
        Parser[ListParser<br/>Markdown → YAML]
        Merger[DataMerger<br/>Multi-source]
        Validator[Validator<br/>8 rules]
        Generator[MarkdownGenerator<br/>Tera templates]
    end
    
    subgraph Models["Models"]
        Repo[Repository<br/>Core model]
        Platform[PlatformInfo<br/>Multi-platform]
        Canon[CanonicalData<br/>Container]
        SyncMeta[SyncMetadata<br/>Sync types]
        FgatToken[FgatToken<br/>token_hash only<br/>raw_token in memory]
        hash[hash_token()<br/>SHA-256 hex]
    end
    
    subgraph Store["Persistence"]
        GraphStore[GraphStore trait<br/>add/list/update/delete FGAT]
        Sqlite[SqliteStore<br/>PRAGMA integrity_check<br/>LIKE escape]
    end
    
    subgraph Security["Security Controls"]
        Redact[redact_sensitive<br/>Token + error redaction]
        Timeouts[HTTP Timeouts<br/>sync:30s, cfg:10s]
        ScopeCheck[Scope Validation<br/>repo, public_repo]
    end
    
    subgraph CrossRefs["Cross-References"]
        Graph[CrossRefGraph<br/>PetGraph]
        Nav[Navigator<br/>Bidirectional]
    end
    
    Main --> SyncOrch
    Main --> Parser
    Main --> Merger
    Main --> Validator
    Main --> Generator
    Main --> ConfigMgr
    
    SyncOrch --> GitHubAdapt
    SyncOrch --> CBAdapt
    SyncOrch --> GLAdapt
    SyncOrch --> SyncCache
    SyncOrch --> Progress
    SyncOrch --> SyncLock
    SyncOrch --> FgatPool
    FgatPool --> Acquired
    
    GitHubAdapt --> CredMgr
    ConfigMgr --> CredMgr
    
    FgatPool --> GraphStore
    GraphStore --> Sqlite
    FgatToken --> hash
    FgatToken --> FgatPool
    
    SyncOrch --> Canon
    Parser --> Canon
    Merger --> Canon
    Validator --> Canon
    Generator --> Canon
    
    Canon --> Repo
    Canon --> Platform
    Canon --> SyncMeta
    
    Validator --> Graph
    Generator --> Nav
    
    GitHubAdapt --> Redact
    GitHubAdapt --> Timeouts
    CredMgr --> Redact
    SyncOrch --> Redact
    Main --> ScopeCheck

