    GitHubAdapt --> CredMgr
    ConfigMgr --> CredMgr
    
    SyncOrch --> Canon
    Parser --> Canon
    Merger --> Canon
    Validator --> Canon
    Generator --> Canon
    
    Canon --> Repo
    Canon --> Platform
    Canon --> SyncMeta
    
    Validator --> Graph
    Generator --> Nav
    
